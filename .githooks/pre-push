#!/usr/bin/env bash
# .githooks/pre-push — Block push if benchmarks regress
#
# Install: bash scripts/install-hooks.sh
# Bypass:  git push --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "========================================"
echo "  bare-metal pre-push hook"
echo "  (bypass with: git push --no-verify)"
echo "========================================"

# Only run on the main repo (not externals).
# After audit Tier 5, scripts/bench_regress.py was retired in favour of
# scripts/bench/bench_regress.R (project's R-only tooling policy).
REGRESS_SCRIPT="scripts/bench/bench_regress.R"
if [ ! -f "$REGRESS_SCRIPT" ]; then
    echo -e "${YELLOW}WARNING: $REGRESS_SCRIPT not found — skipping${NC}"
    exit 0
fi

# Attempt to build benchmarks (best-effort; don't block push on build failure)
echo ""
echo "--- Building benchmarks (make test) ---"
if make test 2>/dev/null; then
    echo -e "${GREEN}Build + smoke tests passed${NC}"
else
    echo -e "${YELLOW}WARNING: make test failed or some benches unbuildable."
    echo "  Regression check will still run on already-built executables.${NC}"
fi

# Static doc audit: every relative link in every README must resolve.
# Cheap (~1s), catches the typical link-rot from directory reorganisations.
echo ""
echo "--- Checking README hyperlinks ---"
LINK_SCRIPT="scripts/audit/check_links.R"
if [ -f "$LINK_SCRIPT" ]; then
    if Rscript "$LINK_SCRIPT"; then
        echo -e "${GREEN}All README links resolve.${NC}"
    else
        echo ""
        echo -e "${RED}BROKEN LINKS DETECTED${NC} (see list above)"
        echo ""
        echo "Fix the README cross-references, then re-push."
        echo "To bypass (for WIP commits):  git push --no-verify"
        exit 1
    fi
else
    echo -e "${YELLOW}WARNING: $LINK_SCRIPT not found — skipping${NC}"
fi

# Run performance regression checker (R + renv)
echo ""
echo "--- Running $REGRESS_SCRIPT ---"
if Rscript "$REGRESS_SCRIPT"; then
    echo ""
    echo -e "${GREEN}All benchmarks within tolerance. Push allowed.${NC}"
    exit 0
else
    echo ""
    echo -e "${RED}BENCHMARK REGRESSION DETECTED${NC}"
    echo ""
    echo "To investigate:"
    echo "  Rscript $REGRESS_SCRIPT --kernel <kernel_path>"
    echo "  Rscript $REGRESS_SCRIPT --tolerance 0.20"
    echo ""
    echo "To update baselines after legitimate improvements:"
    echo "  edit docs/baselines.json"
    echo ""
    echo "To bypass (for WIP commits):"
    echo "  git push --no-verify"
    exit 1
fi
