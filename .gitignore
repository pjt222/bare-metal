# Compiled CUDA binaries
*.cubin
!*_handtuned.sm_86.cubin

# Probe run artifacts (regenerated each run)
scripts/probe/*.log

# Generated SASS disassembly (keep hand-tuned variants)
*.cuasm
!*_handtuned.cuasm

# Compiled executables (not source files)
bench
bench_*
!bench_*.cu
!scripts/bench_*.R
!scripts/bench_*.py
# The `bench` / `bench_*` rules above are for compiled binaries, but
# they also swallow the scripts/bench/ R-source directory. Re-include
# it and its R sources (the compiled kernel `bench` executables live
# under kernels/, not here, so they stay ignored).
!scripts/bench/
!scripts/bench/*.R
!tests/bench_regress/
!tests/bench_regress/**
test_dense_manual
test_mma_sp
test_inplace_race
test_counter
test_persistent
test_persistent_debug
!test_*.cu
verify_wmma_ab_layout
verify_wmma_layout

# Cubin backups
*.cubin.baseline

# Stray temp file from prior session (zero-byte tool error artifact)
, None:0,parameters

# Hugging Face publish artifact: SHA256SUMS is regenerated at upload
# time by scripts/publish_hf.R; never committed (see WS4, issue #109).
SHA256SUMS

# Python
__pycache__/
*.pyc
!scripts/bench_regress.py
!scripts/bench_flash_all.py

# CuAssembler working artifacts
*.cuasm.orig

# Raw SASS reference (generated on-demand via scripts/build.py)
*.sass

# Claude Code / context
.claude/

# Secrets / local environment (never commit real tokens; .env.example is the tracked template)
.env
!.env.example

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.bak

# Quarto build output
docs/analysis/_output/

# OS
.DS_Store
Thumbs.db

# cymatic R-script outputs at project root
cymatic_mapping.csv
cymatic_mapping.rds
cymatic_locality.csv

# IMMA hand-tune experiment artifacts (#96 sub-task A, negative result; the
# generator script was removed after the negative result — recover from git
# history if a rerun is ever needed).
*.imma_s04.sm_86.cubin
*.imma_s02.sm_86.cubin

# phase6 / cuda-oxide spike
# Keep the small comparison artifacts so the README's measured results are
# reproducible from disk, but exclude the upstream NVlabs/cuda-oxide example
# copy (NVIDIA Apache-2.0 — not ours, fetched fresh by run_oxide.sh).
experiments/rust-experiments/vecadd_oxide/
!experiments/rust-experiments/**/*.cubin
!experiments/rust-experiments/**/*.sass
!experiments/rust-experiments/**/*.ptx
# Large data files inside phase6 sub-experiments (regenerable from R scripts)
experiments/rust-experiments/**/perm.bin
experiments/rust-experiments/**/traces.bin
